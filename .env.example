# =========================================
# PDKS - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve doldurun
# =========================================

# --- Veritabanı ---
# Coolify'da PostgreSQL servisi oluşturup connection string'i buraya yapıştırın
DATABASE_URL=postgresql://pdks_admin:pdks_secure_password_123@pdks-db:5432/pdks_saas

# --- Güvenlik Anahtarları ---
# Güçlü rastgele bir string üretin (ör: openssl rand -base64 32)
PDKS_SYSTEM_KEY=guclu_rastgele_bir_jwt_gizli_anahtari_buraya

# --- Push Bildirimleri (Web Push / VAPID) ---
# Aşağıdaki komutla üretin:
# node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PRIVATE_KEY=vapid_ozel_anahtariniz_buraya

# --- Sunucu ---
PORT=8104
NODE_ENV=production
